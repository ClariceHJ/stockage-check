<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>재고↔비재고 전환 모니터</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f5f5f3;color:#2c2c2a;font-size:14px;line-height:1.6}
.wrap{max-width:1280px;margin:0 auto;padding:2rem 1.5rem}
.topbar{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:1.5rem;gap:12px;flex-wrap:wrap}
.topbar h1{font-size:20px;font-weight:600;color:#1a1a18}
.sub{font-size:12px;color:#888780;margin-top:3px}
.btn-row{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
.btn{display:inline-flex;align-items:center;gap:5px;padding:7px 14px;border:1px solid #ccc;border-radius:8px;font-size:13px;cursor:pointer;background:#fff;color:#2c2c2a;white-space:nowrap}
.btn:hover{background:#f0f0ee}
.btn.primary{background:#2c2c2a;color:#fff;border-color:#2c2c2a}
.btn.primary:hover{background:#444}
.btn.sm{padding:4px 10px;font-size:11px}
.cards{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:1.5rem}
@media(max-width:700px){.cards{grid-template-columns:repeat(2,1fr)}}
.card{background:#fff;border-radius:8px;padding:1rem 1.2rem;border:1px solid #e8e8e5}
.card .label{font-size:12px;color:#888780;margin-bottom:4px}
.card .num{font-size:24px;font-weight:600}
.card.flag .num{color:#A32D2D}
.card.safe .num{color:#27500A}
.card.warn .num{color:#633806}
.tabs{display:flex;border-bottom:1px solid #e8e8e5;margin-bottom:1.5rem}
.tab{padding:10px 20px;font-size:13px;cursor:pointer;color:#888780;border-bottom:2px solid transparent;margin-bottom:-1px}
.tab.active{color:#2c2c2a;font-weight:500;border-bottom-color:#2c2c2a}
.tab:hover{color:#2c2c2a}
.panel{display:none}.panel.active{display:block}
.badge{display:inline-block;font-size:11px;font-weight:500;padding:2px 9px;border-radius:999px;white-space:nowrap}
.badge.to-non{background:#FCEBEB;color:#A32D2D}
.badge.to-stock{background:#EAF3DE;color:#27500A}
.badge.ok{background:#f1efe8;color:#5F5E5A}
.badge.watch{background:#FAEEDA;color:#633806}
.tag-row{display:flex;gap:6px;margin-bottom:1rem;flex-wrap:wrap;align-items:center}
.tag-label{font-size:12px;color:#888780}
.tag{font-size:12px;padding:4px 12px;border-radius:999px;border:1px solid #ddd;color:#888780;cursor:pointer;background:#fff}
.tag:hover{background:#f5f5f3}
.tag.a-all{border-color:#2c2c2a;color:#2c2c2a;background:#f0f0ee;font-weight:500}
.tag.a-non{border-color:#E24B4A;color:#A32D2D;background:#FCEBEB;font-weight:500}
.tag.a-stk{border-color:#639922;color:#27500A;background:#EAF3DE;font-weight:500}
.tag.a-wat{border-color:#BA7517;color:#633806;background:#FAEEDA;font-weight:500}
.tbl-wrap{background:#fff;border:1px solid #e8e8e5;border-radius:10px;overflow:auto;margin-bottom:1rem}
table{width:100%;border-collapse:collapse;min-width:980px}
thead th{text-align:left;padding:10px 12px;font-size:12px;font-weight:500;color:#888780;border-bottom:1px solid #e8e8e5;white-space:nowrap;background:#fafaf8}
tbody tr{border-bottom:1px solid #f0f0ee}
tbody tr:last-child{border-bottom:none}
tbody tr:hover{background:#fafaf8}
tbody td{padding:9px 12px;vertical-align:middle}
.spark{display:flex;align-items:flex-end;gap:2px;height:22px}
.spark span{display:inline-block;border-radius:1px;width:5px}
.mono{font-family:'SF Mono',Consolas,monospace;font-size:12px;color:#444}
.empty{text-align:center;padding:4rem 2rem;color:#888780}
.hint{font-size:12px;color:#b4b2a9;line-height:2;margin-top:8px}
.rules{background:#fff;border:1px solid #e8e8e5;border-radius:8px;padding:1rem 1.2rem;font-size:12px;color:#5F5E5A;line-height:2.2}
.cov-hi{color:#A32D2D;font-weight:500}
.cov-md{color:#633806;font-weight:500}
.sync-st{font-size:12px;color:#888780;padding:6px 10px;background:#f5f5f3;border-radius:6px}
.modal-bg{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.4);z-index:100;align-items:center;justify-content:center}
.modal-bg.open{display:flex}
.modal{background:#fff;border-radius:12px;padding:1.5rem;width:440px;max-width:90vw}
.modal h3{font-size:16px;font-weight:600;margin-bottom:1rem}
.modal label{display:block;font-size:12px;color:#888780;margin-bottom:4px;margin-top:12px}
.modal input,.modal select,.modal textarea{width:100%;padding:8px 10px;border:1px solid #ddd;border-radius:6px;font-size:13px;font-family:inherit}
.modal textarea{height:72px;resize:vertical}
.modal-btns{display:flex;gap:8px;justify-content:flex-end;margin-top:1.2rem}
.info-box{font-size:13px;color:#5F5E5A;background:#f5f5f3;padding:10px 12px;border-radius:6px;margin-bottom:4px;line-height:1.7}
.step{display:flex;gap:12px;align-items:flex-start;margin-bottom:1rem}
.step-num{min-width:24px;height:24px;border-radius:50%;background:#2c2c2a;color:#fff;font-size:12px;font-weight:600;display:flex;align-items:center;justify-content:center}
.step-body{font-size:13px;color:#5F5E5A;line-height:1.7}
.step-body strong{color:#2c2c2a}
</style>
</head>
<body>
<div class="wrap">
  <div class="topbar">
    <div>
      <h1>재고↔비재고 전환 모니터</h1>
      <div class="sub" id="last-update">Sheets 동기화 후 주간 CSV를 업로드하세요</div>
    </div>
    <div class="btn-row">
      <span class="sync-st" id="sync-st"></span>
      <button class="btn" onclick="loadFromSheets()">
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><path d="M1 8A7 7 0 1 0 8 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M1 4v4h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Sheets 동기화
      </button>
      <button class="btn" id="export-btn" style="display:none" onclick="exportCSV()">
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><path d="M8 11V1M4 7l4 4 4-4M2 13h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        결과 다운로드
      </button>
      <label class="btn primary">
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><path d="M8 1v10M4 5l4-4 4 4M2 13h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        주간 CSV 업로드
        <input type="file" accept=".csv" id="fileInput" style="display:none">
      </label>
    </div>
  </div>

  <div class="cards">
    <div class="card"><div class="label">전체 품목</div><div class="num" id="c-total">—</div></div>
    <div class="card flag"><div class="label">비재고 전환 권고</div><div class="num" id="c-non">—</div></div>
    <div class="card safe"><div class="label">재고 전환 권고</div><div class="num" id="c-stk">—</div></div>
    <div class="card warn"><div class="label">모니터링</div><div class="num" id="c-wat">—</div></div>
    <div class="card"><div class="label">정상</div><div class="num" id="c-ok">—</div></div>
  </div>

  <div class="tabs">
    <div class="tab active" onclick="switchTab('monitor')">판정 현황</div>
    <div class="tab" onclick="switchTab('history')">전환 이력</div>
    <div class="tab" onclick="switchTab('guide')">사용 가이드</div>
  </div>

  <div class="panel active" id="panel-monitor">
    <div id="main-area">
      <div class="empty">
        <p style="font-size:15px;font-weight:500;margin-bottom:8px">데이터를 불러오세요</p>
        <div class="hint">
          1단계: 우측 상단 <strong>Sheets 동기화</strong> — 기준정보(운영상태 등) 로드<br>
          2단계: <strong>주간 CSV 업로드</strong> — 출고량·재고·출고잔량 로드<br>
          두 데이터가 단품구분자로 매칭되어 판정됩니다
        </div>
        <button class="btn" style="margin-top:1.2rem" onclick="loadSample()">샘플 데이터로 보기</button>
      </div>
    </div>
  </div>

  <div class="panel" id="panel-history">
    <div class="tbl-wrap">
      <table>
        <thead><tr><th>날짜</th><th>단품구분자</th><th>단품명</th><th>이전상태</th><th>변경상태</th><th>사유</th><th>담당자</th></tr></thead>
        <tbody id="history-body">
          <tr><td colspan="7" style="text-align:center;padding:3rem;color:#888780">Sheets 동기화 시 이력이 표시됩니다</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="panel" id="panel-guide">
    <div style="background:#fff;border:1px solid #e8e8e5;border-radius:10px;padding:1.5rem;margin-bottom:1rem">
      <p style="font-size:15px;font-weight:500;margin-bottom:1.2rem">매주 하는 일</p>
      <div class="step">
        <div class="step-num">1</div>
        <div class="step-body"><strong>ERP에서 데이터 추출</strong><br>단품코드, 색상, 당월 누적 출고량, 현재고, 출고잔량</div>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <div class="step-body"><strong>단품구분자 컬럼 생성</strong><br>엑셀 수식: <code>=단품코드셀&"-"&색상셀</code> → SLFC0110A-NWW 형태</div>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <div class="step-body"><strong>CSV 양식에 맞춰 저장</strong><br>컬럼: 단품구분자 | 연월(2025-03) | 출고량 | 현재고 | 출고잔량<br>같은 연월이면 최신값으로 덮어씀, 새 달이 시작되면 행 추가</div>
      </div>
      <div class="step">
        <div class="step-num">4</div>
        <div class="step-body"><strong>대시보드에 업로드</strong><br>Sheets 동기화 → 주간 CSV 업로드 순서로 진행</div>
      </div>
      <div class="step">
        <div class="step-num">5</div>
        <div class="step-body"><strong>전환 권고 품목 확인 후 이력 기록</strong><br>판정 현황 탭에서 권고 품목 확인 → 이력 기록 버튼으로 기록<br>Sheets 전환이력 시트에 자동 반영 예정</div>
      </div>
    </div>
    <div class="rules">
      <strong>판정 기준</strong><br>
      비재고 전환 권고: 재고 운영 + 6개월 평균 ≤ 8개 + 실질재고(현재고-출고잔량) ≤ 5개<br>
      재고 전환 권고: 비재고 운영 + 6개월 평균 ≥ 12개<br>
      모니터링: 경계 구간(평균 8~10개) 또는 비재고 운영 중 피크월 ≥ 15개<br>
      커버리지: 실질재고 ÷ 6개월 평균 — 주황 &gt; 3개월, 빨강 &gt; 6개월
    </div>
  </div>
</div>

<!-- 이력 기록 모달 -->
<div class="modal-bg" id="modal">
  <div class="modal">
    <h3>전환 이력 기록</h3>
    <div class="info-box" id="modal-info"></div>
    <label>사유</label>
    <textarea id="modal-reason" placeholder="전환 사유를 입력해주세요"></textarea>
    <label>담당자</label>
    <input type="text" id="modal-person" placeholder="이름">
    <div class="modal-btns">
      <button class="btn" onclick="closeModal()">취소</button>
      <button class="btn primary" onclick="submitHistory()">기록 저장</button>
    </div>
  </div>
</div>

<script>
const SHEET_ID = '1ivNPbJSqoabJhVkrNV68ASADRN_6iAPsWawe54P69Jk';
const SH_현황 = '재고구분_현황';
const SH_이력 = '재고구분_전환이력';

let masterData = {};  // 단품구분자 → 기준정보 (Sheets에서)
let allData = [];     // 최종 판정 결과
let activeFilter = 'all';
let pendingRecord = null;

// ── 판정 로직 ──
function judge(r) {
  const real = Math.max(0, r.현재고 - r.출고잔량);
  if (r.상태==='재고'   && r.avg6 <= 8  && real <= 5) return 'to-non';
  if (r.상태==='비재고' && r.avg6 >= 12)               return 'to-stock';
  if (r.상태==='재고'   && r.avg6 > 8   && r.avg6 < 10) return 'watch';
  if (r.상태==='재고'   && r.avg6 <= 8  && real > 5)   return 'watch';
  if (r.상태==='비재고' && r.peak >= 15)                return 'watch';
  return 'ok';
}

function badgeHtml(j) {
  return {
    'to-non': '<span class="badge to-non">비재고 전환 권고</span>',
    'to-stock':'<span class="badge to-stock">재고 전환 권고</span>',
    'watch':  '<span class="badge watch">모니터링</span>',
    'ok':     '<span class="badge ok">정상</span>',
  }[j] || '';
}

function sparkHtml(months) {
  const max = Math.max(...months, 1);
  return '<div class="spark">' + months.map(v => {
    const h = Math.max(3, Math.round((v/max)*22));
    const c = v>10?'#E24B4A':v>6?'#EF9F27':'#85B7EB';
    return `<span style="height:${h}px;background:${c}"></span>`;
  }).join('') + '</div>';
}

// ── CSV 파싱 ──
function parseCSV(text) {
  const lines = text.trim().split('\n');
  const headers = lines[0].split(',').map(h => h.trim().replace(/^"|"$/g,''));
  return lines.slice(1).filter(l=>l.trim()).map(line => {
    const vals = line.split(',').map(v=>v.trim().replace(/^"|"$/g,''));
    const obj = {};
    headers.forEach((h,i) => obj[h] = vals[i]||'');
    return obj;
  });
}

// ── 주간 CSV 처리 ──
// 세로 구조: 단품구분자 | 연월 | 출고량 | 현재고 | 출고잔량
function processWeeklyCSV(rows) {
  // 단품구분자별로 그룹핑
  const grouped = {};
  rows.forEach(r => {
    const code = r['단품구분자'];
    if (!code) return;
    if (!grouped[code]) grouped[code] = [];
    grouped[code].push({
      연월: r['연월']||'',
      출고량: parseFloat(r['출고량'])||0,
      현재고: parseFloat(r['현재고'])||0,
      출고잔량: parseFloat(r['출고잔량'])||0,
    });
  });

  // 각 단품별 집계
  const result = [];
  Object.entries(grouped).forEach(([code, entries]) => {
    // 연월 오름차순 정렬
    entries.sort((a,b) => a.연월.localeCompare(b.연월));

    // 최근 6개월 출고량
    const last6 = entries.slice(-6).map(e => e.출고량);
    const avg6 = last6.length > 0 ? last6.reduce((a,b)=>a+b,0)/last6.length : 0;
    const peak = Math.max(...entries.map(e=>e.출고량), 0);

    // 최신 연월의 재고·출고잔량
    const latest = entries[entries.length-1];
    const 현재고 = latest.현재고;
    const 출고잔량 = latest.출고잔량;
    const 연월 = latest.연월;

    // Sheets 기준정보 매칭
    const master = masterData[code] || {};

    const rec = {
      code,
      name: master['단품명'] || code,
      시리즈: master['시리즈'] || '',
      사이즈: master['사이즈'] || '',
      공급처: master['공급처'] || '',
      상태: master['현재상태'] || '재고',
      최종변경일: master['최종변경일'] || '',
      avg6, peak, 현재고, 출고잔량, 연월,
      months: last6,
      verdict: 'ok'
    };
    rec.verdict = judge(rec);
    result.push(rec);
  });

  return result;
}

// ── 렌더링 ──
function render(data) {
  const filtered = activeFilter==='all' ? data : data.filter(r=>r.verdict===activeFilter);
  const cnt = {
    all: data.length,
    'to-non':  data.filter(r=>r.verdict==='to-non').length,
    'to-stock':data.filter(r=>r.verdict==='to-stock').length,
    watch:     data.filter(r=>r.verdict==='watch').length,
    ok:        data.filter(r=>r.verdict==='ok').length,
  };

  document.getElementById('c-total').textContent = cnt.all;
  document.getElementById('c-non').textContent   = cnt['to-non'];
  document.getElementById('c-stk').textContent   = cnt['to-stock'];
  document.getElementById('c-wat').textContent   = cnt.watch;
  document.getElementById('c-ok').textContent    = cnt.ok;
  document.getElementById('export-btn').style.display = data.length ? 'inline-flex' : 'none';

  function tCls(f) {
    if (activeFilter!==f) return 'tag';
    return {all:'tag a-all','to-non':'tag a-non','to-stock':'tag a-stk',watch:'tag a-wat'}[f]||'tag a-all';
  }

  const rows = filtered.length===0
    ? `<tr><td colspan="12" style="text-align:center;padding:2.5rem;color:#888780">해당 항목 없음</td></tr>`
    : filtered.map(r => {
        const real = Math.max(0, r.현재고 - r.출고잔량);
        const cov  = r.avg6 > 0 ? real/r.avg6 : 0;
        const covCls = cov>6?'cov-hi':cov>3?'cov-md':'';
        return `<tr>
          <td class="mono">${r.code}</td>
          <td style="max-width:180px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="${r.name}">${r.name}</td>
          <td style="color:#888780;font-size:12px">${r.시리즈} ${r.사이즈}</td>
          <td><span style="font-size:12px;padding:2px 9px;border-radius:999px;background:${r.상태==='재고'?'#E6F1FB':'#f1efe8'};color:${r.상태==='재고'?'#0C447C':'#444441'}">${r.상태}</span></td>
          <td style="font-weight:500;color:${r.avg6>10?'#A32D2D':r.avg6>6?'#633806':'#2c2c2a'}">${r.avg6.toFixed(1)}</td>
          <td>${r.peak}</td>
          <td>${r.현재고}</td>
          <td style="color:#888780">${r.출고잔량}</td>
          <td style="font-weight:500">${real}</td>
          <td class="${covCls}">${cov.toFixed(1)}개월</td>
          <td>${sparkHtml(r.months)}</td>
          <td>${badgeHtml(r.verdict)}</td>
          <td><button class="btn sm" onclick="openModal('${r.code}','${r.name}','${r.상태}')">이력 기록</button></td>
        </tr>`;
      }).join('');

  document.getElementById('main-area').innerHTML = `
    <div class="tag-row">
      <span class="tag-label">필터</span>
      <span class="${tCls('all')}"      onclick="setFilter('all')">전체 (${cnt.all})</span>
      <span class="${tCls('to-non')}"   onclick="setFilter('to-non')">비재고 전환 권고 (${cnt['to-non']})</span>
      <span class="${tCls('to-stock')}" onclick="setFilter('to-stock')">재고 전환 권고 (${cnt['to-stock']})</span>
      <span class="${tCls('watch')}"    onclick="setFilter('watch')">모니터링 (${cnt.watch})</span>
    </div>
    <div class="tbl-wrap">
      <table>
        <thead><tr>
          <th>단품구분자</th><th>단품명</th><th>시리즈/사이즈</th><th>운영상태</th>
          <th>6개월 평균</th><th>최대월</th><th>현재고</th><th>출고잔량</th>
          <th>실질재고</th><th>커버리지</th><th>추이(6개월)</th><th>판정</th><th></th>
        </tr></thead>
        <tbody>${rows}</tbody>
      </table>
    </div>
    <div class="rules">
      <strong>판정 기준</strong> &nbsp;·&nbsp;
      비재고 전환: 재고 운영 + 6개월 평균 ≤ 8개 + 실질재고 ≤ 5개 &nbsp;·&nbsp;
      재고 전환: 비재고 운영 + 6개월 평균 ≥ 12개 &nbsp;·&nbsp;
      모니터링: 경계 구간(8~10개) 또는 비재고 피크월 ≥ 15개 &nbsp;·&nbsp;
      커버리지 = 실질재고 ÷ 6개월 평균
    </div>`;
}

function setFilter(f) { activeFilter=f; render(allData); }

function switchTab(t) {
  ['monitor','history','guide'].forEach((p,i) => {
    document.querySelectorAll('.tab')[i].classList.toggle('active', p===t);
    document.getElementById('panel-'+p).classList.toggle('active', p===t);
  });
}

// ── Sheets 동기화 ──
async function loadFromSheets() {
  const st = document.getElementById('sync-st');
  st.textContent = '동기화 중...';
  try {
    const url = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:csv&sheet=${encodeURIComponent(SH_현황)}`;
    const res = await fetch(url);
    if (!res.ok) throw new Error();
    const rows = parseCSV(await res.text());
    masterData = {};
    rows.forEach(r => {
      const code = r['단품구분자'];
      if (code) masterData[code] = r;
    });
    st.textContent = `기준정보 ${Object.keys(masterData).length}개 로드 완료`;
    setTimeout(()=>st.textContent='',3000);

    // 이미 CSV 데이터가 있으면 재판정
    if (allData.length > 0) {
      allData.forEach(r => {
        const m = masterData[r.code];
        if (m) { r.상태=m['현재상태']||r.상태; r.name=m['단품명']||r.name; }
        r.verdict = judge(r);
      });
      render(allData);
    }
    loadHistory();
  } catch(e) {
    st.textContent = '동기화 실패 — Sheets 공개 설정을 확인해주세요';
    setTimeout(()=>st.textContent='',4000);
  }
}

async function loadHistory() {
  try {
    const url = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:csv&sheet=${encodeURIComponent(SH_이력)}`;
    const res = await fetch(url);
    const rows = parseCSV(await res.text());
    const tbody = document.getElementById('history-body');
    if (!rows.length) {
      tbody.innerHTML='<tr><td colspan="7" style="text-align:center;padding:2rem;color:#888780">이력 없음</td></tr>';
      return;
    }
    tbody.innerHTML = [...rows].reverse().map(r=>`<tr>
      <td>${r['날짜']||''}</td>
      <td class="mono">${r['단품구분자']||''}</td>
      <td>${r['단품명']||''}</td>
      <td><span class="badge ok">${r['이전상태']||''}</span></td>
      <td><span class="badge to-stock">${r['변경상태']||''}</span></td>
      <td>${r['사유']||''}</td>
      <td>${r['담당자']||''}</td>
    </tr>`).join('');
  } catch(e){}
}

// ── CSV 업로드 ──
document.getElementById('fileInput').addEventListener('change', function(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = ev => {
    const rows = parseCSV(ev.target.result);
    allData = processWeeklyCSV(rows);
    activeFilter = 'all';
    const now = new Date();
    document.getElementById('last-update').textContent =
      `업로드: ${now.toLocaleDateString('ko-KR')} ${now.toLocaleTimeString('ko-KR',{hour:'2-digit',minute:'2-digit'})}  |  ${allData.length}개 품목`;
    render(allData);
  };
  reader.readAsText(file,'UTF-8');
  e.target.value='';
});

// ── 이력 모달 ──
function openModal(code,name,status) {
  pendingRecord={code,name,status};
  const newStatus = status==='재고'?'비재고':'재고';
  document.getElementById('modal-info').innerHTML =
    `<strong>${code}</strong>&nbsp; ${name}<br>현재: <strong>${status}</strong> → 변경: <strong>${newStatus}</strong>`;
  document.getElementById('modal-reason').value='';
  document.getElementById('modal-person').value='';
  document.getElementById('modal').classList.add('open');
}
function closeModal(){document.getElementById('modal').classList.remove('open');pendingRecord=null;}

function submitHistory() {
  if (!pendingRecord) return;
  const reason = document.getElementById('modal-reason').value.trim();
  const person = document.getElementById('modal-person').value.trim();
  if (!reason||!person){alert('사유와 담당자를 입력해주세요');return;}
  const now = new Date();
  const dateStr = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(now.getDate()).padStart(2,'0')}`;
  const newStatus = pendingRecord.status==='재고'?'비재고':'재고';
  const row = [dateStr,pendingRecord.code,pendingRecord.name,pendingRecord.status,newStatus,reason,person];
  const csv = '\uFEFF날짜,단품구분자,단품명,이전상태,변경상태,사유,담당자\n'+row.join(',');
  const a = document.createElement('a');
  a.href = 'data:text/csv;charset=utf-8,'+encodeURIComponent(csv);
  a.download = `이력_${pendingRecord.code}_${dateStr}.csv`;
  a.click();
  alert('이력 파일을 다운로드했습니다.\nGoogle Sheets [재고구분_전환이력] 시트에 붙여넣어 주세요.');
  closeModal();
}

// ── 결과 다운로드 ──
function exportCSV() {
  const h = ['단품구분자','단품명','시리즈','사이즈','운영상태','6개월평균','최대월','현재고','출고잔량','실질재고','커버리지','판정'];
  const r = allData.map(r=>{
    const real=Math.max(0,r.현재고-r.출고잔량);
    const cov=r.avg6>0?(real/r.avg6).toFixed(1):'0';
    return [r.code,r.name,r.시리즈,r.사이즈,r.상태,r.avg6.toFixed(1),r.peak,r.현재고,r.출고잔량,real,cov,
      {'to-non':'비재고 전환 권고','to-stock':'재고 전환 권고',watch:'모니터링',ok:'정상'}[r.verdict]];
  });
  const csv='\uFEFF'+[h,...r].map(x=>x.join(',')).join('\n');
  const a=document.createElement('a');
  a.href='data:text/csv;charset=utf-8,'+encodeURIComponent(csv);
  a.download=`재고전환판정_${new Date().toISOString().slice(0,10)}.csv`;
  a.click();
}

